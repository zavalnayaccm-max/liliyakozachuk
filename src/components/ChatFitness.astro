---
/**
 * Визуал Кейса 1 - обезличенная реконструкция диалога.
 * Источник сценария: business/assets/case-fitness-reconstruction.md.
 *
 * Почему реконструкция, а не скриншот: на реальных скринах переписки
 * персональные данные клиентов студии и чужой бренд. На публичный сайт они не
 * идут. Здесь всё вымышленное: студия «Ритм», клиент Марина, номер
 * +7 900 123-45-67 заведомо фейковый. Время 23:47 - принципиально, оно и есть
 * доказательство: бот работает, когда администратор спит.
 *
 * Подпись «Пример работы бота» - обязательная часть, а не украшение. Выдать
 * реконструкцию за реальный скрин значит соврать в первом же доказательстве.
 */

const dialogue = [
  { from: 'client', text: 'Здравствуйте! Подскажите стоимость индивидуального занятия?' },
  {
    from: 'bot',
    text: 'Добро пожаловать в студию «Ритм» 🌿\nПо какому филиалу вопрос - Центральная или Парковая?',
  },
  { from: 'client', text: 'Центральная' },
  {
    from: 'bot',
    text: 'Индивидуальное занятие - от 1 900 ₽, точная цена зависит от тренера.\nХотите, запишу вас? Оставьте номер телефона и удобное время - менеджер подтвердит запись.',
  },
  { from: 'client', text: '+7 900 123-45-67, можно в выходные утром' },
  {
    from: 'bot',
    text: 'Записала 🌙 Менеджер свяжется с вами в ближайшее рабочее время.\nХорошего вечера!',
  },
];
---

<figure class="night rounded-3xl p-5 sm:p-7">
  <div class="flex items-center justify-between border-b border-white/10 pb-4">
    <span class="stamp">Студия «Ритм»</span>
    <span class="stamp text-amber">23:47</span>
  </div>

  <div class="mt-5 space-y-3">
    {
      dialogue.map((line) =>
        line.from === 'bot' ? (
          <p class="bubble bubble-in max-w-[88%] whitespace-pre-line">{line.text}</p>
        ) : (
          <div class="flex justify-end">
            <p class="bubble bubble-out max-w-[80%] whitespace-pre-line">{line.text}</p>
          </div>
        )
      )
    }
  </div>

  <figcaption class="mt-6 border-t border-white/10 pt-4 text-sm text-mist">
    Пример работы бота. Диалог собран заново: студия, имя и номер вымышленные,
    механика настоящая.
  </figcaption>
</figure>
