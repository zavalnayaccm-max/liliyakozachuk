---
/**
 * Экран 4. Не верьте на слово. Потрогайте.
 *
 * План, 4.3: демо - сильнейший приём на всей странице, экран не сжимать.
 * Жмут сроки - режем красоту, не режем демо.
 *
 * Текста для этого экрана в site-copy.md нет (он заблокирован фазой А0, пока не
 * собран свой демо-бот). Отсюда взяты только заголовок и надпись на кнопке,
 * копирайт не выдумывался.
 *
 * TODO (А0): как только демо-бот собран - вписать ссылку в
 * `demoBotUrl` в src/data/content.ts. Кнопка включится сама, заглушка исчезнет.
 * Клиентских ботов сюда не ставим ни при каких условиях (план, 4.3).
 */
import { demoBotUrl } from '../data/content';
---

<section class="night relative overflow-hidden py-20 sm:py-28">
  <div
    aria-hidden="true"
    class="pointer-events-none absolute top-1/3 -left-32 h-[28rem] w-[28rem] rounded-full opacity-50 blur-3xl"
    style="background: radial-gradient(circle, rgba(75,57,239,0.45) 0%, rgba(75,57,239,0) 70%);"
  >
  </div>

  <div class="shell relative">
    <p class="eyebrow">Живое демо</p>
    <h2 class="h-section mt-4 max-w-3xl text-white">Не верьте на слово. Потрогайте.</h2>

    <div class="mt-12 grid gap-6 lg:grid-cols-5 lg:gap-8">
      {/* Главный блок экрана - свой демо-бот */}
      <div
        class="rounded-3xl bg-ink-2 p-6 ring-1 ring-white/10 sm:p-8 lg:col-span-3 lg:p-10"
      >
        <div class="flex items-center gap-3">
          <span class="h-2.5 w-2.5 rounded-full bg-amber"></span>
          <span class="stamp">Демо-бот</span>
        </div>

        <div class="mt-6 space-y-3">
          <p class="bubble bubble-in max-w-[85%]">
            Привет! Я бот. Сейчас покажу, как выгляжу изнутри.
          </p>
          <div class="flex justify-end">
            <p class="bubble bubble-out max-w-[70%]">Давай</p>
          </div>
          {/* Индикатор набора: та же деталь, что в любом мессенджере.
              При системной настройке «меньше движения» просто замирает. */}
          <div class="flex items-center gap-1.5 pt-1 pl-4" aria-hidden="true">
            <span class="typing-dot"></span>
            <span class="typing-dot" style="animation-delay: 0.18s"></span>
            <span class="typing-dot" style="animation-delay: 0.36s"></span>
          </div>
        </div>

        <div class="mt-8">
          {
            demoBotUrl ? (
              <a
                href={demoBotUrl}
                class="cta w-full sm:w-auto"
                target="_blank"
                rel="noopener noreferrer"
              >
                Нажмите и пройдите сами
              </a>
            ) : (
              <>
                {/* Заглушка: демо-бота ещё нет. Это не ссылка и не кнопка -
                    нажимать нечего, поэтому и не интерактивный элемент, чтобы
                    не сбивать чтение с экрана ложным «отключённая ссылка». */}
                <span class="cta w-full sm:w-auto" aria-disabled="true">
                  Нажмите и пройдите сами
                </span>
                <p class="mt-4 text-sm leading-relaxed text-mist">
                  Демо-бот собирается. Кнопка заработает, как только он будет
                  готов.
                </p>
              </>
            )
          }
        </div>
      </div>

      {/* Второй способ потрогать - игровая механика в кейсе ниже. Анимацию
          не дублируем: она тяжёлая, и на странице ей место одно - в карточке
          кейса, где рядом стоят цифры и объяснение. */}
      <div
        class="flex flex-col justify-between rounded-3xl border border-white/12 p-6 sm:p-8 lg:col-span-2 lg:p-10"
      >
        <div>
          <p class="stamp">Игровая механика</p>
          <p class="mt-5 text-base leading-relaxed text-[#c8d0e0]">
            Баллы за активность, обмен на коллекционные карточки, приз за
            собранную коллекцию. Ниже эта петля показана целиком, в движении.
          </p>
        </div>
        <a
          href="#case-game"
          class="group mt-8 inline-flex items-center gap-2 font-mono text-sm text-amber underline decoration-amber/40 underline-offset-4 hover:decoration-amber"
        >
          Посмотреть, как она работает
          <span aria-hidden="true" class="transition-transform group-hover:translate-y-0.5"
            >&#8595;</span
          >
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .typing-dot {
    display: block;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background-color: var(--color-mist);
    animation: typing 1.2s ease-in-out infinite;
  }

  @keyframes typing {
    0%,
    60%,
    100% {
      opacity: 0.3;
      transform: translateY(0);
    }
    30% {
      opacity: 1;
      transform: translateY(-3px);
    }
  }
</style>
