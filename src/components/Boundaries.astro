---
/**
 * Экран 7. За что не берусь.
 * Текст - site-copy.md, экран 7.
 *
 * Стоит перед квизом намеренно: честные границы отсекают мусорные заявки и
 * поднимают доверие ко всему, что человек прочитал выше. Оформлен тише
 * остальных экранов - это не продажа, а условия.
 */

const limits = [
  {
    title: 'Не правлю чужой код и не доделываю за прошлым разработчиком.',
    body: 'Беру только проекты с нуля. Моя скорость появляется на чистом старте, а в чужой базе она исчезает - там я буду не быстрее обычного разработчика, и нанимать меня станет незачем.',
  },
  {
    title: 'Не рисую дизайн с нуля.',
    body: 'Работаю на готовых компонентах: выходит быстро и аккуратно. Если нужен уникальный авторский дизайн - это не ко мне.',
  },
  {
    title: 'Не беру большие нагруженные системы',
    body: 'маркетплейсы, биржи, всё, где тысячи людей одновременно. Мой размер - малый бизнес и эксперты.',
    joinWithDash: true,
  },
];
---

<section class="pb-20 sm:pb-28">
  <div class="shell">
    <p class="eyebrow">Условия</p>
    <h2 class="h-section mt-4">За что не берусь</h2>

    <ul class="mt-10 max-w-3xl space-y-8">
      {
        limits.map((limit) => (
          <li class="border-l-2 border-ink/15 pl-5">
            <p class="text-base leading-relaxed text-graphite sm:text-[1.0625rem]">
              <strong class="font-semibold text-ink">{limit.title}</strong>
              {limit.joinWithDash ? ' - ' : ' '}
              {limit.body}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
