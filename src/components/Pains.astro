---
/**
 * Экран 2. Узнаёте себя?
 * Текст - site-copy.md, экран 2. Четыре боли дословно из avatar.md: это живые
 * фразы клиентов, поэтому и поданы как реплики - входящие сообщения, а не
 * пункты списка. Пояснение стоит под пузырём отдельной строкой: реплика
 * принадлежит клиенту, комментарий - мне, и путать их нельзя.
 */

const pains = [
  {
    quote: 'Клиенты пишут вечером и в воскресенье, когда никого нет - и уходят',
    note: 'Заявок немного, но каждая утекшая заметна.',
  },
  {
    quote: 'Сотрудник сто раз в день отправляет одно и то же сообщение',
    note: 'Человек занят рутиной вместо работы, за которую вы ему платите.',
  },
  {
    quote: 'Аудитория есть, а продаж нет',
    note: 'Подписчики набраны, но их никто не прогревает и не доводит до покупки.',
  },
  {
    quote: 'Воронка придумана, но без бота она не собирается',
    note: 'Механизм есть на бумаге, не хватает одной детали.',
  },
];
---

<section class="py-20 sm:py-28">
  <div class="shell">
    <p class="eyebrow">Четыре фразы, которые я слышу чаще всего</p>
    <h2 class="h-section mt-4">Узнаёте себя?</h2>

    <ul class="mt-12 grid gap-8 sm:grid-cols-2 sm:gap-x-10 sm:gap-y-12">
      {
        pains.map((pain) => (
          <li>
            <p class="bubble bubble-in shadow-[0_1px_2px_rgba(14,21,36,0.06)] sm:text-base">
              {pain.quote}
            </p>
            <p class="mt-3 pl-1 text-sm leading-relaxed text-graphite sm:text-[0.9375rem]">
              {pain.note}
            </p>
          </li>
        ))
      }
    </ul>

    <p
      class="mt-12 border-t border-ink/10 pt-6 font-display text-lg leading-snug font-medium tracking-tight sm:text-xl"
    >
      Если хотя бы одно - это чинится. Обычно за несколько дней.
    </p>
  </div>
</section>
