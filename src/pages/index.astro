---
// Фаза А1: страница-заглушка. Её единственная задача - доказать, что цепочка
// «код Astro → GitHub Actions → GitHub Pages → домен liliyakozachuk.ru»
// работает и открывается из РФ по https. Реальный лендинг - в фазе А3.
import Layout from '../layouts/Layout.astro';
---

<Layout title="liliyakozachuk.ru - скоро здесь будет сайт">
  <main class="flex min-h-dvh flex-col items-center justify-center gap-4 px-6 text-center">
    <h1 class="text-3xl font-semibold tracking-tight sm:text-4xl">
      Скоро здесь будет сайт
    </h1>
    <p class="max-w-md text-balance text-base text-neutral-500">
      Боты, воронки и сайты для малого бизнеса. Страница собрана на Astro и
      развёрнута на GitHub Pages - проверяем, что домен открывается из России.
    </p>
    <p class="text-sm text-neutral-400">liliyakozachuk.ru</p>
  </main>
</Layout>
