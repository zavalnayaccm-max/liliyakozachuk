---
// Базовый макет. Один на весь сайт: сюда подключаются глобальные стили,
// отсюда же задаётся язык, кодировка и мета. Все ресурсы - локальные,
// ни одного внешнего <link>/<script> (требование под РФ, см. план 3.2).
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Лилия Козачук - боты, воронки и сайты для малого бизнеса',
  description = 'Убираю ручную рутину: чат-боты, ИИ-ассистенты, воронки и сайты за дни, а не за месяцы.',
} = Astro.props;

// Пути к статике в public/ должны учитывать base (сайт живёт в подпапке на
// GitHub Pages). BASE_URL приходит из astro.config; срезаем возможный
// завершающий слэш, чтобы `${base}/файл` не давал двойной слэш и не склеивался.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <link rel="icon" href={`${base}/favicon.ico`} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {/* Цвет строки браузера на телефоне - под тёмный первый экран */}
    <meta name="theme-color" content="#0e1524" />
    {/* Превью ссылки в мессенджерах: сайт кидают в переписку, это его основной
        способ распространения. Картинки превью нет намеренно - её пришлось бы
        держать в репозитории, а своей графики пока нет. */}
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ru_RU" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
  </head>
  <body>
    <a href="#main" class="skip-link">Перейти к содержанию</a>
    <slot />
  </body>
</html>

<style>
  /* Ссылка для тех, кто ходит по странице с клавиатуры: видна только при
     фокусе, иначе не мешает. */
  .skip-link {
    position: absolute;
    left: -9999px;
    top: 0;
    z-index: 50;
  }
  .skip-link:focus {
    left: 0.75rem;
    top: 0.75rem;
    background-color: var(--color-violet);
    color: #fff;
    padding: 0.75rem 1rem;
    border-radius: 0.5rem;
  }
</style>
